#!/bin/bash
# FoxML AI Status — Waybar module for OpenCode model status.
# Display reads as a peer of the memory module: "<icon> <size> X/Yg",
# where X is the loaded model's GPU footprint (from `ollama ps`) and Y
# is total VRAM. Falls back to "idle" when no model is resident.

CONFIG_FILE="$HOME/.config/opencode/opencode.json"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo '{"text": "  OFF", "tooltip": "OpenCode config not found", "class": "offline"}'
    exit 0
fi

MODEL_FULL=$(jq -r '.model // empty' "$CONFIG_FILE")
if [[ -z "$MODEL_FULL" || "$MODEL_FULL" == "null" ]]; then
    echo '{"text": "  OFF", "tooltip": "No model set in config", "class": "offline"}'
    exit 0
fi

MODEL_NAME="${MODEL_FULL#*/}"
SIZE=$(echo "$MODEL_NAME" | grep -ioP '\d+[bB]' | head -n1 | tr '[:lower:]' '[:upper:]')
DISPLAY_TAG="${SIZE:-${MODEL_NAME:0:8}}"

# ── Total VRAM (GB, one decimal) ─────────────────────────────────
vram_total_gb=""
if command -v nvidia-smi &>/dev/null; then
    vram_total_mb=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null \
                    | head -1 | tr -d ' ')
    if [[ "$vram_total_mb" =~ ^[0-9]+$ ]] && (( vram_total_mb > 0 )); then
        vram_total_gb=$(awk -v mb="$vram_total_mb" 'BEGIN { printf "%.1f", mb/1024 }')
    fi
fi

# ── Loaded model footprint from `ollama ps` ──────────────────────
# SIZE column embeds a space ("6.0 GB"), so grep the line for the
# pattern instead of relying on awk column counts.
loaded_size_gb=""
loaded_proc=""
loaded_name=""
if command -v ollama &>/dev/null; then
    ps_line=$(ollama ps 2>/dev/null | awk 'NR==2 { print; exit }')
    if [[ -n "$ps_line" ]]; then
        loaded_name=$(awk '{print $1}' <<<"$ps_line")
        # "6.0 GB" or "512 MB" — normalize to GB with one decimal
        if [[ "$ps_line" =~ ([0-9]+\.?[0-9]*)[[:space:]]*(GB|MB) ]]; then
            val="${BASH_REMATCH[1]}"
            unit="${BASH_REMATCH[2]}"
            if [[ "$unit" == "MB" ]]; then
                loaded_size_gb=$(awk -v v="$val" 'BEGIN { printf "%.1f", v/1024 }')
            else
                loaded_size_gb=$(awk -v v="$val" 'BEGIN { printf "%.1f", v }')
            fi
        fi
        # PROCESSOR column like "100% GPU" / "50%/50% CPU/GPU"
        if [[ "$ps_line" =~ ([0-9]+%[[:space:]]*[A-Z/]+) ]]; then
            loaded_proc="${BASH_REMATCH[1]}"
        fi
    fi
fi

# ── Compose text + class ─────────────────────────────────────────
ICON=""
CLASS="smart"
if [[ -n "$SIZE" ]]; then
    num=$(echo "$SIZE" | tr -dc '0-9')
    if [[ -n "$num" ]]; then
        if   (( num <= 8 ));  then CLASS="fast"
        elif (( num <= 20 )); then CLASS="smart"
        else                       CLASS="expert"
        fi
    fi
fi

if [[ -n "$loaded_size_gb" && -n "$vram_total_gb" ]]; then
    TEXT="$ICON $DISPLAY_TAG $loaded_size_gb/${vram_total_gb}g"
elif [[ -n "$loaded_size_gb" ]]; then
    TEXT="$ICON $DISPLAY_TAG ${loaded_size_gb}g"
else
    TEXT="$ICON $DISPLAY_TAG idle"
fi

# ── Tooltip ──────────────────────────────────────────────────────
tip="Model: $MODEL_NAME"
if [[ -n "$loaded_name" ]]; then
    tip+="\\nLoaded: $loaded_name"
    [[ -n "$loaded_size_gb" ]] && tip+=" (${loaded_size_gb}g)"
    [[ -n "$loaded_proc"    ]] && tip+="  $loaded_proc"
else
    tip+="\\nLoaded: (idle)"
fi
[[ -n "$vram_total_gb" ]] && tip+="\\nVRAM total: ${vram_total_gb}g"

printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$TEXT" "$tip" "$CLASS"
