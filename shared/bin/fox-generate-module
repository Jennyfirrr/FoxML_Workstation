#!/bin/bash
# fox-generate-module — Scaffold a new C++ module for fox-install.
#
# Creates the .cpp file, adds the FOX_MODULE entry to modules.def,
# and adds the required stub to test_registry.cpp.

set -e

NAME=$1
if [[ -z "$NAME" ]]; then
    echo "Usage: fox generate-module <name> [description]"
    exit 1
fi

DESC="${2:-What $NAME does}"

FOXML_DIR="$HOME/code/Linux_Theme"
[[ -d "$FOXML_DIR" ]] || FOXML_DIR="."

CPP_FILE="$FOXML_DIR/src/fox-install/modules/$NAME.cpp"
DEF_FILE="$FOXML_DIR/src/fox-install/core/modules.def"
TEST_FILE="$FOXML_DIR/src/fox-install/tests/test_registry.cpp"

if [[ -f "$CPP_FILE" ]]; then
    echo "Error: Module '$NAME' already exists at $CPP_FILE"
    exit 1
fi

# 1. Create .cpp file
cat <<EOF > "$CPP_FILE"
#include "../core/context.hpp"
#include "../core/shell.hpp"
#include "../core/ui.hpp"

namespace fox_install {

void run_$NAME(Context& ctx) {
    ui::section("Setting up $NAME");
    
    // ui::substep("Doing something...");
    // sh::pacman({"some-package"});
    // sh::systemctl_enable("some.service", /*user=*/false);
}

}  // namespace fox_install
EOF

# 2. Update modules.def
# Try to find a good spot (before Phase 4) or just append before the GPU section.
if grep -q "Phase 4" "$DEF_FILE"; then
    sed -i "/Phase 4/i FOX_MODULE( $NAME, run_$NAME, \"--$NAME\", \"$DESC\", false )" "$DEF_FILE"
else
    echo "FOX_MODULE( $NAME, run_$NAME, \"--$NAME\", \"$DESC\", false )" >> "$DEF_FILE"
fi

# 3. Update test_registry.cpp
# Append before the closing brace of the namespace.
sed -i "/}  \/\/ namespace fox_install/i void run_$NAME(Context&) {}" "$TEST_FILE"

echo ":: Created module '$NAME'"
echo "   + $CPP_FILE"
echo "   + Updated $DEF_FILE"
echo "   + Updated $TEST_FILE"
echo ":: Run 'make' in $FOXML_DIR to rebuild the orchestrator."
