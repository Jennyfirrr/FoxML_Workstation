#!/bin/bash
# fox-template-lint — Check if all {{TOKEN}}s in templates are defined in the palette.
#
# Scans templates/ for placeholders and verifies they exist in the 
# reference FoxML_Classic palette. Handles _R/_G/_B and _HEX suffixes.

set -e

FOXML_DIR="$HOME/code/Linux_Theme"
[[ -d "$FOXML_DIR" ]] || FOXML_DIR="."
PALETTE="$FOXML_DIR/themes/FoxML_Classic/palette.sh"

if [[ ! -f "$PALETTE" ]]; then
    echo "Error: Reference palette not found at $PALETTE"
    exit 1
fi

# Extract defined tokens from palette.sh
# Matches lines like: BG=1a1214
defined_tokens=$(grep -E '^[A-Z0-9_]+=' "$PALETTE" | cut -d= -f1)

# Extract tokens from templates
echo ":: Scanning templates for tokens..."
errors=0
found_tokens=$(find "$FOXML_DIR/templates" -type f -exec grep -oE '\{\{[A-Z0-9_]+\}\}' {} + | sed -E 's/.*\{\{(.*)\}\}/\1/' | sort -u)

for token in $found_tokens; do
    base=$token
    # Strip suffixes
    base=${base%_R}
    base=${base%_G}
    base=${base%_B}
    base=${base%_HEX}
    
    if ! echo "$defined_tokens" | grep -qxw "$base"; then
        echo "  [FAIL] {{$token}} used in templates but '$base' not defined in palette.sh"
        errors=$((errors + 1))
    fi
done

if (( errors > 0 )); then
    echo ":: Total errors: $errors"
    exit 1
else
    echo "  [OK] All tokens verified."
    exit 0
fi
