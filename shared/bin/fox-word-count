#!/bin/bash
# fox-word-count — Word count utility for the current workspace

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Default exclusions (directories)
EXCLUDE_DIRS=(
    ".git"
    "node_modules"
    "dist"
    "build"
    ".aider.tags.cache.v4"
    ".claude"
    ".opencode"
    ".git-rewrite"
    "__pycache__"
    "venv"
    ".venv"
    ".foxml_index.json"
)

# Default exclusions (file patterns - though we use grep -I to skip binaries)
EXCLUDE_FILES=(
    "*.png"
    "*.jpg"
    "*.jpeg"
    "*.gif"
    "*.svg"
    "*.pdf"
    "*.zip"
    "*.tar.gz"
    "*.o"
    "*.so"
    "*.a"
    "*.exe"
    "*.bin"
    "*.pyc"
    "*.lock"
    "*-lock.json"
)

usage() {
    echo "Usage: fox-word-count [path]"
    echo "Counts words, lines, and characters in text files, excluding common noise."
    exit 1
}

TARGET_DIR="${1:-.}"

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: Directory $TARGET_DIR not found."
    exit 1
fi

cd "$TARGET_DIR" || exit 1

echo -e "${BLUE}FoxML Word Count${NC}"
echo -e "Scanning ${BOLD}$(pwd)${NC}..."

# Build exclusion arguments for grep
EXCLUDE_ARGS=""
for dir in "${EXCLUDE_DIRS[@]}"; do
    EXCLUDE_ARGS+=" --exclude-dir=$dir"
done

for file in "${EXCLUDE_FILES[@]}"; do
    EXCLUDE_ARGS+=" --exclude=$file"
done

# Get all text files (non-binary)
# grep -I skips binary files
# grep -r searches recursively
# grep -l prints only filenames
FILES=$(grep -rIl "" . $EXCLUDE_ARGS 2>/dev/null)

if [[ -z "$FILES" ]]; then
    echo "No text files found."
    exit 0
fi

# Summary by extension
echo -e "\n${BOLD}Breakdown by file type:${NC}"
# Extract extension, count them, sort by frequency
echo "$FILES" | rev | cut -d/ -f1 | cut -d. -f1 | rev | grep -v "^\." | sort | uniq -c | sort -rn | head -n 10 | awk '{printf "  %-10s %s\n", $2 ":", $1}'

# Total counts
# xargs wc provides the "total" line at the end if multiple files, or just the file line if one
STATS=$(echo "$FILES" | xargs wc -l -w -c 2>/dev/null | tail -n 1)

LINES=$(echo "$STATS" | awk '{print $1}')
WORDS=$(echo "$STATS" | awk '{print $2}')
CHARS=$(echo "$STATS" | awk '{print $3}')

# Fallback to zero if empty
LINES="${LINES:-0}"
WORDS="${WORDS:-0}"
CHARS="${CHARS:-0}"

# Human readable size for chars (approx bytes)
HUMAN_SIZE=$(numfmt --to=iec --suffix=B "$CHARS" 2>/dev/null || echo "$CHARS")

echo -e "\n${BOLD}Totals:${NC}"
echo -e "  Lines:      ${GREEN}$LINES${NC}"
echo -e "  Words:      ${GREEN}$WORDS${NC}"
echo -e "  Characters: ${GREEN}$CHARS ($HUMAN_SIZE)${NC}"
echo -e "  Files:      ${GREEN}$(echo "$FILES" | wc -l)${NC}"
